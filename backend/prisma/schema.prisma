generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GolferLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum TrainingCategory {
  PUTTING
  SHORT_GAME
  IRON_PLAY
  DRIVING
  COURSE_MANAGEMENT
  MENTAL_GAME
}

enum TrainingDifficulty {
  EASY
  MEDIUM
  HARD
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum ClubType {
  DRIVER
  FAIRWAY_WOOD
  HYBRID
  IRON
  WEDGE
  PUTTER
}

enum GoalType {
  HCP_TARGET
  ROUNDS_COUNT
  SCORE_TARGET
  CUSTOM
}

enum HazardType {
  WATER
  BUNKER
  OB
  ROUGH
  TREES
}

enum ShotShape {
  STRAIGHT
  FADE
  DRAW
}

model User {
  id                     String      @id @default(cuid())
  email                  String      @unique
  password               String
  name                   String
  handicap               Float?
  level                  GolferLevel @default(BEGINNER)
  homeClub               String?
  emailVerified          Boolean     @default(false)
  emailVerificationToken String?     @unique
  avatarUrl              String?
  pushToken              String?
  notifTraining          Boolean     @default(true)
  notifStreak            Boolean     @default(true)
  notifWeather           Boolean     @default(false)
  notifFriends           Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  userTrainingPlans UserTrainingPlan[]
  courses           Course[]
  rounds            Round[]
  assessments       Assessment[]
  sessionLogs       TrainingSessionLog[]
  drillResults      DrillResult[]
  handicapEntries   HandicapEntry[]
  streak            UserStreak?
  badges            UserBadge[]
  clubs             Club[]
  goals             UserGoal[]
  sentRequests        Friendship[]        @relation("FriendshipRequester")
  receivedRequests    Friendship[]        @relation("FriendshipAddressee")
  wearables           WearableConnection[]
  drillSets           DrillSet[]
  scheduledTrainings  ScheduledTraining[]
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model Club {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      ClubType
  distanceM Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserGoal {
  id          String    @id @default(cuid())
  userId      String
  type        GoalType
  title       String
  targetValue Float?
  deadline    DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastTrainedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Assessment {
  id        String   @id @default(cuid())
  userId    String
  answers   Json
  scores    Json
  weaknesses String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainingDrill {
  id          String             @id @default(cuid())
  name        String
  description String
  duration    Int
  category    TrainingCategory
  difficulty  TrainingDifficulty
  videoUrl    String?
  tips        String[]
  isLibrary   Boolean            @default(false)
  canDoAtHome Boolean            @default(false)

  trainingDayDrills TrainingDayDrill[]
  results           DrillResult[]
  drillSetItems     DrillSetItem[]
}

model DrillResult {
  id         String   @id @default(cuid())
  userId     String
  drillId    String
  userPlanId String?
  dayNumber  Int?
  hits       Int
  attempts   Int
  createdAt  DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  drill TrainingDrill @relation(fields: [drillId], references: [id], onDelete: Cascade)
}

model TrainingDay {
  id           String           @id @default(cuid())
  dayNumber    Int
  title        String
  focus        TrainingCategory
  totalMinutes Int              @default(0)
  planId       String

  plan   TrainingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  drills TrainingDayDrill[]
}

model TrainingDayDrill {
  trainingDayId String
  drillId       String
  order         Int    @default(0)

  trainingDay TrainingDay   @relation(fields: [trainingDayId], references: [id], onDelete: Cascade)
  drill       TrainingDrill @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@id([trainingDayId, drillId])
}

model TrainingPlan {
  id            String      @id @default(cuid())
  name          String
  description   String
  targetLevel   GolferLevel
  durationWeeks Int
  isTemplate    Boolean     @default(false)
  createdAt     DateTime    @default(now())

  days              TrainingDay[]
  userTrainingPlans UserTrainingPlan[]
}

model UserTrainingPlan {
  id             String   @id @default(cuid())
  userId         String
  planId         String
  startDate      DateTime @default(now())
  currentDay     Int      @default(1)
  completedDays  Int[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        TrainingPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  sessionLogs TrainingSessionLog[]

  @@unique([userId, planId])
}

model TrainingSessionLog {
  id         String   @id @default(cuid())
  userId     String
  userPlanId String
  dayNumber  Int
  feeling    Int      // 1–5: 1=sehr schlecht, 3=okay, 5=großartig
  difficulty Int      // 1–5: 1=zu leicht, 3=genau richtig, 5=zu schwer
  notes      String?
  createdAt  DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPlan UserTrainingPlan @relation(fields: [userPlanId], references: [id], onDelete: Cascade)
}

model HandicapEntry {
  id        String   @id @default(cuid())
  userId    String
  handicap  Float
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Hazard {
  id          String    @id @default(cuid())
  type        HazardType
  description String
  position    String
  holeId      String

  hole Hole @relation(fields: [holeId], references: [id], onDelete: Cascade)
}

model HoleStrategy {
  id             String    @id @default(cuid())
  recommendedClub String
  shotShape      ShotShape
  aimPoint       String
  avoidance      String
  notes          String
  shots          Json      @default("[]")
  holeId         String    @unique

  hole Hole @relation(fields: [holeId], references: [id], onDelete: Cascade)
}

model Hole {
  id              String  @id @default(cuid())
  number          Int
  par             Int
  strokeIndex     Int
  distanceMeters  Int
  courseId        String

  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hazards  Hazard[]
  strategy HoleStrategy?
}

model Course {
  id            String   @id @default(cuid())
  name          String
  location      String
  totalPar      Int      @default(72)
  rating        Float?
  slope         Float?
  createdBy     String?  // null = API-importiert
  apiId         String?            // GolfCourseAPI ID
  holesImported Boolean  @default(false)
  createdAt     DateTime @default(now())

  creator User?   @relation(fields: [createdBy], references: [id])
  holes   Hole[]
  rounds  Round[]
}

model HoleScore {
  id                 String   @id @default(cuid())
  holeNumber         Int
  par                Int
  strokes            Int
  putts              Int
  fairwayHit         Boolean?
  greenInRegulation  Boolean
  penalties          Int      @default(0)
  notes              String?
  roundId            String

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model WearableConnection {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // 'APPLE_HEALTH' | 'GARMIN'
  garminUserId String?
  accessToken  String?
  refreshToken String?
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?
  syncData     Json?     // latest snapshot: { steps, heartRate, calories, activeMinutes }

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model DrillSet {
  id        String            @id @default(cuid())
  userId    String?
  name      String
  category  TrainingCategory?
  isPreset  Boolean           @default(false)
  color     String            @default("#FF6535")
  createdAt DateTime          @default(now())

  user               User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              DrillSetItem[]
  scheduledTrainings ScheduledTraining[]

  @@index([userId])
}

model DrillSetItem {
  id          String  @id @default(cuid())
  drillSetId  String
  drillId     String?
  customName  String?
  durationMin Int     @default(10)
  order       Int     @default(0)

  drillSet DrillSet       @relation(fields: [drillSetId], references: [id], onDelete: Cascade)
  drill    TrainingDrill? @relation(fields: [drillId], references: [id], onDelete: SetNull)

  @@index([drillSetId])
}

model ScheduledTraining {
  id              String            @id @default(cuid())
  userId          String
  date            DateTime
  title           String
  category        TrainingCategory?
  drillSetId      String?
  notes           String?
  completed       Boolean           @default(false)
  completedAt     DateTime?
  calendarEventId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  drillSet DrillSet? @relation(fields: [drillSetId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model Round {
  id                   String   @id @default(cuid())
  userId               String
  courseId             String
  date                 DateTime
  weather              String?
  notes                String?
  handicapDifferential Float?   // WHS-Differenzial: (Brutto - Course Rating) × 113 / Slope
  courseHandicap       Int?     // Spielvorgabe für diese Runde
  createdAt            DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course      @relation(fields: [courseId], references: [id])
  scores   HoleScore[]
}
