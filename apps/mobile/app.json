{
  "expo": {
    "name": "FairwayIQ",
    "slug": "fairwayiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fairwayiq",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fairwayiq.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "FairwayIQ verwendet die Kamera nicht.",
        "NSHealthShareUsageDescription": "FairwayIQ liest Fitness- und Aktivit\u00e4tsdaten f\u00fcr deine Golfrunden.",
        "NSHealthUpdateUsageDescription": "FairwayIQ speichert keine Gesundheitsdaten."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070f"
      },
      "package": "com.fairwayiq.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FairwayIQ benötigt deinen Standort für aktuelle Wetterdaten und Spielempfehlungen."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
